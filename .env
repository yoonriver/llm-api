APP_NAME=Bedrock Claude FastAPI Server
ENVIRONMENT=local
MOCK_MODEL_NAME=mock-claude

AWS_REGION=us-east-1
USE_BEDROCK=false

API_KEY=dev-secret-key
LLM_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

USE_AWS_STORAGE=false
LOCAL_ARTIFACTS_DIR=local_artifacts
LOCAL_HISTORY_FILE=local_history.json

DDB_TABLE=local-history
S3_BUCKET=local-bucket